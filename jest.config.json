{
  "name": "glassERP Frontend Tests",
  "displayName": "Glass ERP - Frontend Testing Suite",
  "testEnvironment": "jsdom",
  "setupFilesAfterEnv": [
    "<rootDir>/tests/unit/frontend/setup.js"
  ],
  "moduleNameMapping": {
    "^@/(.*)$": "<rootDir>/resources/js/$1",
    "^@frontend/(.*)$": "<rootDir>/resources/js/$1",
    "^@components/(.*)$": "<rootDir>/resources/js/Components/$1",
    "^@features/(.*)$": "<rootDir>/resources/js/Pages/$1",
    "^@shared/(.*)$": "<rootDir>/resources/js/utils/$1"
  },
  "testMatch": [
    "<rootDir>/tests/unit/frontend/**/*.test.{js,jsx,ts,tsx}",
    "<rootDir>/resources/js/**/__tests__/**/*.{js,jsx,ts,tsx}",
    "<rootDir>/resources/js/**/*.{test,spec}.{js,jsx,ts,tsx}"
  ],
  "transform": {
    "^.+\\.(js|jsx|ts|tsx)$": ["babel-jest", {
      "presets": [
        ["@babel/preset-env", { "targets": { "node": "current" } }],
        ["@babel/preset-react", { "runtime": "automatic" }],
        "@babel/preset-typescript"
      ]
    }]
  },
  "collectCoverageFrom": [
    "resources/js/**/*.{js,jsx,ts,tsx}",
    "!resources/js/**/*.d.ts",
    "!resources/js/**/*.stories.{js,jsx,ts,tsx}",
    "!resources/js/**/index.{js,jsx,ts,tsx}"
  ],
  "coverageDirectory": "<rootDir>/coverage/frontend",
  "coverageReporters": [
    "text",
    "lcov",
    "html",
    "json-summary"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 80,
      "functions": 80,
      "lines": 80,
      "statements": 80
    }
  },
  "moduleFileExtensions": [
    "js",
    "jsx",
    "ts",
    "tsx",
    "json"
  ],
  "testPathIgnorePatterns": [
    "<rootDir>/node_modules/",
    "<rootDir>/vendor/",
    "<rootDir>/tests/e2e/"
  ],
  "transformIgnorePatterns": [
    "node_modules/(?!(@heroui|@inertiajs)/)"
  ]
}
