# --- Session / auth idle-timeout policy (see docs/session-expiry-policy.md) ---
# SESSION_LIFETIME is the SINGLE source of truth for the idle window and drives
# BOTH web session expiry AND mobile Sanctum token expiry. 480 = 8h idle.
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
# Do NOT log web users out on browser close (mobile tokens have no such behavior).
SESSION_EXPIRE_ON_CLOSE=false
# 'lax' (not 'strict') so the cookie survives cross-site top-level navigations.
SESSION_SAME_SITE=lax
# MUST be true in production (HTTPS). Leave unset/false for local http.
SESSION_SECURE_COOKIE=false
SESSION_PATH=/
# Leave EMPTY for a single host (host-only cookie). Do NOT set it to the bare host
# (e.g. erp.example.com): adding a Domain attribute (a) forks the cookie from any
# pre-existing host-only cookie in already-visited browsers -> duplicate same-named
# cookies -> 419 "page expired" on login, and (b) widens scope to all subdomains.
# Only set a leading-dot value (e.g. .example.com) if the cookie MUST span subdomains.
SESSION_DOMAIN=
# Bump this name once if you ever change SESSION_DOMAIN in production: a fresh cookie
# name makes every browser ignore stale/forked cookies (fleet-wide one-time re-login).
# SESSION_COOKIE=dbedc_guardian_session

# Multi-Factor Authentication
MFA_GRACE_PERIOD_DAYS=7

# CAPTCHA Configuration
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=recaptcha_v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_THRESHOLD=0.5
CAPTCHA_FAILED_ATTEMPTS_THRESHOLD=3
CAPTCHA_NEW_DEVICE=true
CAPTCHA_UNUSUAL_LOCATION=true
CAPTCHA_OUTSIDE_BUSINESS_HOURS=true
CAPTCHA_BUSINESS_HOURS_START=06:00
CAPTCHA_BUSINESS_HOURS_END=18:00

# Geolocation Configuration
CAPTCHA_CHECK_COUNTRY=true
CAPTCHA_SUSPICIOUS_COUNTRIES=
CAPTCHA_DISTANCE_THRESHOLD_KM=500

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=null
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379


