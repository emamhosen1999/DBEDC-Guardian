{
  "rules": {
    ".read": false,
    ".write": false,
    "signals": {
      "notif": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": false
        }
      },
      "$ns": {
        "$entity": {
          ".read": "auth != null",
          ".write": false
        }
      }
    }
  }
}
